generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  EMPLOYEE
  ADMIN
}

model User {
  id       Int     @id @default(autoincrement())
  username String  @unique
  password String
  name     String
  email    String? @unique
  enabled  Boolean @default(true)
  role     Role    @default(EMPLOYEE)
  enrollId String? // Removed unique constraint so multiple devices can map to same or different enrollIds
  dept     String?

  attendanceLogs       AttendanceLog[]
  wfhLogs              WFHLog[]
  leaveBalances        LeaveBalance[]
  leaveRecords         LeaveRecord[]
  deviceEnrollments    DeviceEnrollment[]
  fingerprintTemplates FingerprintTemplate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DeviceEnrollment {
  id           Int       @id @default(autoincrement())
  deviceId     String    // "1" = Office 1 (RAMS), "2" = Office 2 (RIMS)
  enrollId     String    // raw biometric enroll ID from scanner
  userId       Int
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  note         String?   // optional admin note
  syncStatus   String    @default("PENDING") // "PENDING", "SYNCED", "FAILED"
  syncError    String?
  lastSyncedAt DateTime?
  isLogVisible Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([deviceId, enrollId])
}

model FingerprintTemplate {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fingerId  Int      // 0-9
  template  String   // base64 template string
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, fingerId])
}

model AttendanceLog {
  id            Int     @id @default(autoincrement())
  dept          String?
  scannerUserId String?
  name          String?
  enrollId      String?
  deviceId      String?
  place         String?
  date          String
  time          String
  attType       String?
  verifyMoc     String?
  remark        String?

  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
}

model WFHLog {
  id        Int     @id @default(autoincrement())
  userId    Int
  user      User    @relation(fields: [userId], references: [id])
  date      String
  startTime String?
  endTime   String?
  hours     Float
  remarks   String?

  createdAt DateTime @default(now())
}

model Holiday {
  id        Int      @id @default(autoincrement())
  date      String   @unique
  name      String
  createdAt DateTime @default(now())
}

model LeaveBalance {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  year      Int
  month     Int      @default(0) // 0 represents the yearly/historical record or yearly total, 1-12 represents a specific month
  planned   Float    @default(0)
  emergency Float    @default(0)
  lop       Float    @default(0)
  pending   Float    @default(0)
  total     Float    @default(0)

  @@unique([userId, year, month])
}

model LeaveRecord {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  date      String   // YYYY-MM-DD
  type      String   // 'PL', 'EL', 'LOP', 'Pending'
  createdAt DateTime @default(now())

  @@unique([userId, date])
}

model SyncJob {
  id        String   @id
  status    String   @default("PENDING") // "PENDING", "PROCESSING", "COMPLETED", "FAILED"
  rangeType String
  startDate String?
  endDate   String?
  result    String?  // JSON string or summary message
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
